HOST=0.0.0.0
# PORT задаёт Railway автоматически — не переопределяйте на проде без необходимости

DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

GEMINI_API_KEY=
GEMINI_ANALYZE_MODEL=gemini-3.1-flash-lite
GEMINI_ANALYZE_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_LESSON_ANALYZE_MODEL=
GEMINI_LESSON_ANALYZE_FALLBACK_MODELS=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_FRAME_MODEL=gemini-3.1-flash-lite
GEMINI_LIVE_FRAME_FALLBACK_MODELS=
# Live-снапшоты (HLS ingest) — через Gemini. Vision/Py: см. docs/LIVE_ANALYSIS_GEMINI_VS_PYTHON.md.
GEMINI_LIVE_MODE=live
LIVE_CAPTURE_INTERVAL_MS=10000
LIVE_CAPTURE_MIN_INTERVAL_MS=250
# Railway/облако: если DNS не резолвит HLS-хост (v-guard.kz), подставьте IP:
# LIVE_HLS_RESOLVE=v-guard.kz=38.107.235.151
MAX_CONCURRENT_LIVE_INGEST=5
GEMINI_LIVE_MAX_CONCURRENT=2
LIVE_RECORDING_TMP_DIR=
LIVE_INCIDENT_DEDUP_SEC=30
LIVE_RETENTION_DAYS=30
LIVE_RETENTION_CRON_HOURS=24
LIVE_RESUME_ON_BOOT=true
LIVE_AUTO_EXPORT_LESSON=true
LIVE_START_RATE_LIMIT_PER_MIN=6
LIVE_MAX_PAYLOAD_BYTES=262144
LIVE_MAX_JPEG_BYTES=2097152
LIVE_TMP_MIN_FREE_MB=512

# Пайплайн через qoz-vision: задать URL и MODE (см. docs/LIVE_ANALYSIS_GEMINI_VS_PYTHON.md). Сейчас — выкл.
VISION_LIVE_URL=
VISION_LIVE_MODE=off
VISION_LIVE_TIMEOUT_MS=60000
VISION_LIVE_MAX_RETRIES=2
VISION_LIVE_MAX_CONCURRENT=1
VISION_INTERNAL_SECRET=
VISION_LIVE_DRIVER=off

INCIDENT_ANALYZE_MODE=vision
INCIDENT_VISION_MAX_FRAMES=0
INCIDENT_VISION_ALL_FRAMES=true
INCIDENT_VISION_SAMPLE_FPS=1
INCIDENT_VISION_MIN_CONF=0.4
INCIDENT_ANALYZE_TMP_DIR=
INCIDENT_ANALYZE_TIMEOUT_MS=300000

# Уроки: gemini (default) | pipeline (Whisper stub + YOLO + Qwen stub)
LESSON_ANALYZE_MODE=gemini
LESSON_ANALYZE_TIMEOUT_MS=900000
LESSON_ANALYZE_TMP_DIR=
LOCAL_WHISPER_URL=http://localhost:8000/api/transcribe
LOCAL_VISION_URL=
LOCAL_LLM_URL=http://localhost:8001/v1/chat/completions
LESSON_WHISPER_PLACEHOLDER=true
LESSON_LLM_PLACEHOLDER=true
LESSON_VISION_SAMPLE_SEC=10
LESSON_LOG_WINDOW_SEC=300
LESSON_VISION_MAX_CONCURRENT=4
LESSON_VISION_RUN_ALL_SPECIALIZED=false
LESSON_LOG_MAX_CHARS=120000
LESSON_LOG_TAIL_PRESERVE_SEC=600
LESSON_LLM_MODEL=Qwen/Qwen2.5-32B-Instruct-AWQ
LESSON_LLM_MAX_RETRIES=2
LESSON_PIPELINE_SAVE_DEBUG_LOG=false

SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_ENDPOINT=https://YOUR_REF.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-south-1
STORAGE_BUCKET=records

BACKEND_INTERNAL_SECRET=
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
