HOST=0.0.0.0
# PORT задаёт Railway автоматически — не переопределяйте на проде без необходимости

DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

GEMINI_API_KEY=
GEMINI_ANALYZE_MODEL=gemini-3.1-flash-lite
GEMINI_ANALYZE_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_LESSON_ANALYZE_MODEL=
GEMINI_LESSON_ANALYZE_FALLBACK_MODELS=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_LIVE_FRAME_MODEL=gemini-3.1-flash-lite
GEMINI_LIVE_FRAME_FALLBACK_MODELS=
GEMINI_LIVE_MODE=auto
LIVE_CAPTURE_INTERVAL_MS=10000

SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_ENDPOINT=https://YOUR_REF.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-south-1
STORAGE_BUCKET=records

BACKEND_INTERNAL_SECRET=
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
